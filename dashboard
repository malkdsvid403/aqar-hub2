<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8" />
    <title>داشبورد العقارات</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Bootstrap CDN -->
    <link
        rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css"
    />

    <!-- Chart.js CDN -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>

    <style>
        body {
            background-color: #f5f5f5;
            font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        }
        .card {
            margin-bottom: 1rem;
        }
        .kpi-value {
            font-size: 1.6rem;
            font-weight: 700;
        }
        .kpi-label {
            color: #777;
        }
        .table thead {
            background-color: #f0f0f0;
        }
    </style>
</head>
<body class="p-3">

    <!-- العنوان -->
    <div class="container-fluid mb-3">
        <div class="d-flex justify-content-between align-items-center">
            <h3 class="mb-0">لوحة تحكم العقارات</h3>
            <span class="text-muted">نموذج تجريبي – يمكنك تعديله كما تشاء</span>
        </div>
    </div>

    <div class="container-fluid">
        <!-- KPIs -->
        <div class="row">
            <div class="col-md-2 col-6">
                <div class="card text-center">
                    <div class="card-body">
                        <div class="kpi-label">عدد العقارات</div>
                        <div class="kpi-value" id="kpi-properties">12</div>
                    </div>
                </div>
            </div>
            <div class="col-md-2 col-6">
                <div class="card text-center">
                    <div class="card-body">
                        <div class="kpi-label">نسبة الإشغال</div>
                        <div class="kpi-value" id="kpi-occupancy">87%</div>
                    </div>
                </div>
            </div>
            <div class="col-md-2 col-6">
                <div class="card text-center">
                    <div class="card-body">
                        <div class="kpi-label">متوسط الإيجار</div>
                        <div class="kpi-value" id="kpi-avg-rent">4,800 ر.س</div>
                    </div>
                </div>
            </div>
            <div class="col-md-2 col-6">
                <div class="card text-center">
                    <div class="card-body">
                        <div class="kpi-label">الدخل الشهري</div>
                        <div class="kpi-value" id="kpi-income">
